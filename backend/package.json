{
  "name": "sayona-shipping-backend",
  "version": "2.0.0",
  "description": "Enterprise-grade logistics SaaS platform — Express + PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "npm run migrate && npm run seed && node server.js",
    "dev": "npx nodemon server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "setup": "npm run migrate && npm run seed",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "test": "jest --detectOpenHandles --forceExit",
    "worker": "node worker.js"
  },
  "keywords": [
    "shipping",
    "logistics",
    "enterprise",
    "saas",
    "express",
    "postgresql"
  ],
  "author": "Sayona Shipping",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-jaeger": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "opossum": "^9.0.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pm2": "^6.0.14",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
